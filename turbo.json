{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "DATABASE_URL",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_API_KEY",
        "PAYPAL_CLIENT_ID",
        "PAYPAL_SECRET",
        "NEXT_PUBLIC_PAYPAL_CLIENT_ID",
        "RESEND_API_KEY",
        "RESEND_FROM",
        "QDRANT_URL",
        "QDRANT_API_KEY",
        "ADMIN_EMAIL",
        "CRON_SECRET",
        "GOOGLE_SERVICE_ACCOUNT_KEY",
        "TAVILY_API_KEY",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_TENANT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "MICROSOFT_REDIRECT_URI"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
